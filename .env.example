# Supabase — client (required for Vite dev/build)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the Project API "anon" JWT from the dashboard, OR a publishable key (not both required):
VITE_SUPABASE_ANON_KEY=your_anon_jwt_or_leave_blank_if_using_publishable
# Optional: newer publishable key (see Supabase API settings)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server / CLI only — never use VITE_ prefix (would leak to the browser).
# SUPABASE_ACCESS_TOKEN=   # for `supabase` CLI
# SUPABASE_SERVICE_ROLE_KEY=  # for trusted server scripts only; never in frontend
#
# Node seed scripts (`scripts/*.mjs`) read the same URL/keys from the environment.
# Minimal local test data: npm run seed:min  (loads .env automatically; needs service role key)
